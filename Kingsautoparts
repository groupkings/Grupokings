<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kings Auto Parts · BMW F30 com DNA de M3</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,500;0,600&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --gold:#C6A036;--gold-light:#d4ae3d;--gold-dim:rgba(198,160,54,0.15);
  --gold-border:rgba(198,160,54,0.3);--dark:#0a0a0a;--dark2:#111111;
  --dark3:#161616;--dark4:#1c1c1c;--white:#fff;
  --muted:rgba(255,255,255,0.5);--dim:rgba(255,255,255,0.22);
  --border:rgba(255,255,255,0.07);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--dark);color:var(--white);font-family:'Barlow',sans-serif;overflow-x:hidden;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--dark)}
::-webkit-scrollbar-thumb{background:var(--gold);border-radius:2px}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:12px 40px;background:rgba(10,10,10,0.96);backdrop-filter:blur(14px);border-bottom:0.5px solid var(–border);animation:fadeDown .5s ease both;gap:16px}
.nav-logo{height:40px;width:auto;object-fit:contain}
.nav-links{display:flex;gap:24px;list-style:none}
.nav-links a{font-family:‘Barlow Condensed’,sans-serif;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(–muted);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(–gold)}
.nav-cta{display:inline-flex;align-items:center;gap:8px;background:var(–gold);color:var(–dark);font-family:‘Barlow Condensed’,sans-serif;font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:10px 20px;border-radius:2px;text-decoration:none;transition:background .2s;white-space:nowrap;flex-shrink:0}
.nav-cta:hover{background:var(–gold-light)}
.nav-cta svg{width:14px;height:14px;fill:var(–dark)}

/* ── HERO ── */
.hero{min-height:100vh;position:relative;overflow:hidden;display:flex;align-items:flex-end}
.hero-bg{position:absolute;inset:0;background-image:url(‘data:image/jpeg;base64,’);background-size:cover;background-position:center 35%;filter:brightness(0.33)}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,10,1) 0%,rgba(10,10,10,.5) 42%,rgba(10,10,10,.04) 100%)}
.hero-grid{position:absolute;inset:0;background-image:repeating-linear-gradient(90deg,transparent,transparent 80px,rgba(198,160,54,.022) 80px,rgba(198,160,54,.022) 81px)}
.hero-content{position:relative;z-index:2;padding:0 40px 68px;width:100%;max-width:660px}
.hero-tag{display:flex;align-items:center;gap:12px;margin-bottom:18px;animation:fadeUp .7s .2s ease both}
.tag-line{width:30px;height:1.5px;background:var(–gold)}
.tag-txt{font-family:‘Barlow Condensed’,sans-serif;font-size:11px;letter-spacing:.22em;color:var(–gold);text-transform:uppercase;font-weight:600}
.hero h1{font-family:‘Bebas Neue’,sans-serif;font-size:clamp(62px,11vw,115px);line-height:.88;letter-spacing:3px;margin-bottom:20px;animation:fadeUp .7s .35s ease both}
.hero h1 .g{color:var(–gold)}
.hero h1 .o{-webkit-text-stroke:1px rgba(255,255,255,.18);color:transparent}
.hero-sub{font-size:15px;color:var(–muted);font-weight:300;max-width:420px;line-height:1.7;margin-bottom:32px;animation:fadeUp .7s .5s ease both}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;animation:fadeUp .7s .65s ease both}
.btn-pri{display:inline-flex;align-items:center;gap:10px;background:var(–gold);color:var(–dark);font-family:‘Barlow Condensed’,sans-serif;font-size:15px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:15px 30px;border-radius:2px;text-decoration:none;transition:background .2s,transform .15s}
.btn-pri:hover{background:var(–gold-light);transform:translateY(-1px)}
.btn-sec{display:inline-flex;align-items:center;gap:8px;border:0.5px solid var(–gold-border);color:var(–gold);font-family:‘Barlow Condensed’,sans-serif;font-size:15px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;padding:15px 30px;border-radius:2px;text-decoration:none;transition:background .2s}
.btn-sec:hover{background:var(–gold-dim)}
.hero-badges{display:flex;gap:8px;flex-wrap:wrap;margin-top:36px;animation:fadeUp .7s .8s ease both}
.hbadge{padding:5px 12px;border:0.5px solid rgba(255,255,255,.1);color:var(–muted);font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-family:‘Barlow Condensed’,sans-serif;font-weight:600;border-radius:2px}

/* ── SECTION ── */
section{padding:88px 40px}
.stag{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.stag-line{width:22px;height:1.5px;background:var(–gold)}
.stag-txt{font-family:‘Barlow Condensed’,sans-serif;font-size:11px;letter-spacing:.2em;color:var(–gold);text-transform:uppercase;font-weight:600}
.stitle{font-family:‘Bebas Neue’,sans-serif;font-size:clamp(34px,5vw,50px);letter-spacing:2px;margin-bottom:6px}
.ssub{font-size:14px;color:var(–muted);font-weight:300;margin-bottom:48px;max-width:500px;line-height:1.6}

/* ── KIT HERO BANNER ── */
.kit-banner{width:100%;height:320px;object-fit:cover;object-position:center 40%;display:block;margin-bottom:40px;border:0.5px solid var(–border)}

/* ── PRODUTO CARDS ── */
#produtos{background:var(–dark2)}
.prod-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:2px;margin-bottom:2px}
.prod-card{background:var(–dark3);border:0.5px solid var(–border);overflow:hidden;transition:border-color .3s}
.prod-card:hover{border-color:var(–gold-border)}
.prod-img{width:100%;height:230px;object-fit:cover;object-position:center;display:block;transition:transform .4s ease}
.prod-card:hover .prod-img{transform:scale(1.04)}
.prod-img-wrap{overflow:hidden;position:relative}
.prod-img-tag{position:absolute;bottom:12px;left:12px;background:rgba(10,10,10,.82);border:0.5px solid var(–gold-border);padding:4px 12px;font-family:‘Barlow Condensed’,sans-serif;font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(–gold)}
.prod-body{padding:26px}
.prod-name{font-family:‘Barlow Condensed’,sans-serif;font-size:19px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-bottom:6px}
.prod-desc{font-size:13px;color:var(–muted);line-height:1.6;margin-bottom:18px;font-weight:300}
.prod-items{list-style:none;margin-bottom:22px}
.prod-items li{display:flex;align-items:center;gap:9px;font-size:13px;color:rgba(255,255,255,.48);padding:6px 0;border-bottom:0.5px solid rgba(255,255,255,.04)}
.prod-items li:last-child{border-bottom:none}
.dot{width:4px;height:4px;background:var(–gold);border-radius:50%;flex-shrink:0}
.prod-price{font-family:‘Bebas Neue’,sans-serif;font-size:36px;color:var(–gold);letter-spacing:1px}
.prod-note{font-size:11px;color:var(–dim);font-style:italic;margin-top:2px}

/* ── PARALAMAS CARD (full width, mobile-friendly) ── */
.paralamas-card{background:var(–dark3);border:0.5px solid var(–border);overflow:hidden;margin-top:2px;transition:border-color .3s}
.paralamas-card:hover{border-color:var(–gold-border)}
.paralamas-img{width:100%;height:260px;object-fit:contain;object-position:center;display:block;background:var(–dark4)}
.paralamas-body{padding:26px}
.paralamas-incl{display:inline-block;background:rgba(40,160,80,0.12);border:0.5px solid rgba(40,160,80,0.3);color:#3cd474;font-family:‘Barlow Condensed’,sans-serif;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:4px 12px;border-radius:2px;margin-bottom:14px}

/* ── COMBO ── */
.combo{background:linear-gradient(135deg,var(–dark3) 0%,#141209 100%);border:0.5px solid var(–gold-border);padding:32px 36px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-top:2px}
.combo-left{}
.combo-label{font-family:‘Barlow Condensed’,sans-serif;font-size:11px;font-weight:600;letter-spacing:.2em;color:var(–gold);text-transform:uppercase;margin-bottom:8px}
.combo-title{font-family:‘Bebas Neue’,sans-serif;font-size:30px;letter-spacing:2px;margin-bottom:6px}
.combo-desc{font-size:13px;color:var(–muted);font-weight:300;max-width:420px}
.combo-note{font-size:11px;color:var(–dim);font-style:italic;margin-top:6px}
.combo-right{text-align:right;flex-shrink:0}
.combo-old{font-size:13px;color:var(–dim);text-decoration:line-through;margin-bottom:3px}
.combo-price{font-family:‘Bebas Neue’,sans-serif;font-size:50px;color:var(–gold);letter-spacing:2px;line-height:1}
.combo-save{display:inline-block;margin-top:5px;background:var(–gold-dim);color:var(–gold);font-size:11px;padding:3px 12px;border-radius:2px;font-family:‘Barlow Condensed’,sans-serif;font-weight:700;letter-spacing:.1em}

/* ── RESULTADO ── */
#resultado{padding:0}
.res-wrap{display:grid;grid-template-columns:1fr 1fr}
.res-img{height:500px;overflow:hidden}
.res-img img{width:100%;height:100%;object-fit:cover;object-position:center left}
.res-body{padding:64px 48px;display:flex;flex-direction:column;justify-content:center;background:var(–dark2)}
.res-body .ssub{margin-bottom:28px}
.res-stats{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(–border);margin-top:36px}
.stat{background:var(–dark3);padding:22px 18px}
.stat-n{font-family:‘Bebas Neue’,sans-serif;font-size:34px;color:var(–gold);letter-spacing:1px}
.stat-l{font-size:11px;color:var(–dim);letter-spacing:.05em;margin-top:2px;font-family:‘Barlow Condensed’,sans-serif;text-transform:uppercase}

/* ── DIFERENCIAIS ── */
#diferenciais{background:var(–dark3)}
.dif-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1px;background:var(–border);border:0.5px solid var(–border)}
.dif{background:var(–dark2);padding:32px 26px;transition:background .2s}
.dif:hover{background:var(–dark3)}
.dif-ico{width:38px;height:38px;border:0.5px solid var(–gold-border);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:16px}
.dif-ico svg{width:17px;height:17px;stroke:var(–gold);fill:none;stroke-width:1.5}
.dif h3{font-family:‘Barlow Condensed’,sans-serif;font-size:15px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-bottom:8px}
.dif p{font-size:13px;color:var(–muted);line-height:1.6;font-weight:300}

/* ── PPF CORES ── */
#ppf{background:var(–dark2)}
.ppf-strip{display:grid;grid-template-columns:260px 1fr;gap:0;margin-bottom:48px;border:0.5px solid var(–border);overflow:hidden}
.ppf-strip-img{height:180px;object-fit:cover;object-position:center;display:block;width:100%}
.ppf-strip-body{padding:24px 28px;display:flex;flex-direction:column;justify-content:center;background:var(–dark3);border-left:0.5px solid var(–border)}
.ppf-strip-body strong{display:block;font-family:‘Barlow Condensed’,sans-serif;font-size:16px;font-weight:700;color:var(–gold);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px}
.ppf-strip-body p{font-size:13px;color:var(–muted);line-height:1.5;font-weight:300}

.ppf-section-title{font-family:‘Barlow Condensed’,sans-serif;font-size:13px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(–muted);margin-bottom:16px;margin-top:36px;padding-bottom:8px;border-bottom:0.5px solid var(–border)}
.ppf-colors{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px}
.color-chip{display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(–dark3);border:0.5px solid var(–border);border-radius:2px;font-size:12px;color:var(–muted);font-family:‘Barlow Condensed’,sans-serif;letter-spacing:.03em;transition:border-color .2s;cursor:default}
.color-chip:hover{border-color:var(–gold-border);color:var(–white)}
.chip-dot{width:14px;height:14px;border-radius:50%;flex-shrink:0;border:0.5px solid rgba(255,255,255,.1)}
.ppf-cta-row{display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-top:32px;padding-top:28px;border-top:0.5px solid var(–border)}
.ppf-cta-text{font-size:14px;color:var(–muted);font-weight:300;flex:1}
.ppf-cta-text strong{color:var(–white);font-weight:500}
.btn-outline{display:inline-flex;align-items:center;gap:8px;border:0.5px solid var(–gold-border);color:var(–gold);font-family:‘Barlow Condensed’,sans-serif;font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:12px 22px;border-radius:2px;text-decoration:none;flex-shrink:0;transition:background .2s}
.btn-outline:hover{background:var(–gold-dim)}

/* ── CTA FINAL ── */
#contato{background:var(–dark);text-align:center;padding:110px 40px;position:relative;overflow:hidden}
#contato::before{content:’’;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,rgba(198,160,54,.06) 0%,transparent 70%);pointer-events:none}
.cta-eye{font-family:‘Barlow Condensed’,sans-serif;font-size:12px;letter-spacing:.22em;color:var(–gold);text-transform:uppercase;font-weight:600;margin-bottom:14px}
#contato h2{font-family:‘Bebas Neue’,sans-serif;font-size:clamp(42px,7vw,72px);letter-spacing:3px;line-height:.92;margin-bottom:18px}
#contato h2 span{color:var(–gold)}
#contato > p{font-size:15px;color:var(–muted);font-weight:300;max-width:420px;margin:0 auto 44px;line-height:1.7}
.cta-big{display:inline-flex;align-items:center;gap:14px;background:var(–gold);color:var(–dark);font-family:‘Bebas Neue’,sans-serif;font-size:21px;letter-spacing:2px;padding:18px 44px;border-radius:2px;text-decoration:none;transition:background .2s,transform .15s}
.cta-big:hover{background:var(–gold-light);transform:translateY(-2px)}
.cta-big svg{width:20px;height:20px;fill:var(–dark)}
.cta-notes{margin-top:22px;display:flex;gap:28px;justify-content:center;flex-wrap:wrap}
.cta-note{font-size:12px;color:var(–dim);letter-spacing:.04em;display:flex;align-items:center;gap:6px}
.cta-note::before{content:’—’;color:var(–gold)}

/* ── FOOTER ── */
footer{padding:24px 40px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;border-top:0.5px solid var(–border)}
.foot-brand{font-family:‘Bebas Neue’,sans-serif;font-size:19px;letter-spacing:3px;color:rgba(255,255,255,.45)}
.foot-brand span{color:var(–gold)}
footer p{font-size:12px;color:var(–dim)}

/* ── WA FLOAT ── */
.wa-float{position:fixed;bottom:24px;right:24px;z-index:200;display:flex;align-items:center;gap:10px;background:#25D366;color:#fff;font-family:‘Barlow Condensed’,sans-serif;font-size:14px;font-weight:700;letter-spacing:.07em;padding:13px 20px 13px 15px;border-radius:50px;text-decoration:none;box-shadow:0 4px 18px rgba(37,211,102,.3);transition:transform .2s,box-shadow .2s;animation:fadeUp .7s 1.2s ease both}
.wa-float:hover{transform:translateY(-2px);box-shadow:0 8px 26px rgba(37,211,102,.4)}
.wa-float svg{width:19px;height:19px;fill:#fff;flex-shrink:0}

/* ── ANIMS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeDown{from{opacity:0;transform:translateY(-14px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── SVG ICON HELPER ── */
.ico svg{width:18px;height:18px;fill:currentColor;flex-shrink:0}

/* ── MOBILE ── */
@media(max-width:768px){
nav{padding:12px 18px}
.nav-links{display:none}
section{padding:64px 18px}
.hero-content{padding:0 18px 60px}
.ppf-strip{grid-template-columns:1fr}
.ppf-strip-body{border-left:none;border-top:0.5px solid var(–border)}
.res-wrap{grid-template-columns:1fr}
.res-img{height:240px}
.res-body{padding:44px 18px}
.combo{padding:24px 18px}
.combo-right{text-align:left}
footer{padding:18px}
.wa-float{bottom:18px;right:18px}
}
</style>

</head>
